# Postgres local de desarrollo (levantado con docker-compose.yml)
POSTGRES_USER=telco_user
POSTGRES_PASSWORD=telco_pass
POSTGRES_DB=telco_churn
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Usada por el backend (SQLAlchemy) para conectarse a Postgres
DATABASE_URL=postgresql+psycopg://telco_user:telco_pass@localhost:5432/telco_churn
